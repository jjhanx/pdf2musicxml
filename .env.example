# pdf2musicxml вҖ” нҷҳкІҪ ліҖмҲҳ мҳҲмӢң (ліөмӮ¬ нӣ„ .env лҳҗлҠ” pm2 ecosystemм—җ м„Өм •)
# Windows PowerShell: Copy-Item .env.example .env
# Linux bash: cp .env.example .env

# в”Җв”Җ OMR м—”м§„ (кё°ліё: AI) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# ai (кё°ліё) | audiveris (л Ҳкұ°мӢң)
OMR_ENGINE=ai

# AI OMR
AI_OMR_BACKEND=mock
# tromr мӮ¬мҡ© мӢң: pip install -r requirements-ai.txt
AI_OMR_MODEL=sanderwood/tr-omr-large
AI_OMR_DPI=300
AI_OMR_DIVISIONS=6
AI_OMR_SYSTEMS_MODE=auto
AI_OMR_SYSTEMS_PER_PAGE=4
AI_OMR_SPLIT_STAVES=1
AI_OMR_STAVES_PER_SYSTEM=6
AI_OMR_SAVE_SYMBOL_GRAPH=1

# Audiveris (OMR_ENGINE=audiveris л Ҳкұ°мӢңмқј л•Ңл§Ң)
# AUDIVERIS_BIN=/opt/audiveris/bin/Audiveris
# AUDIVERIS_OCR_LANG=eng

# MXL нӣ„мІҳлҰ¬ (лҰ¬л“¬ м¶”м • off к¶ҢмһҘ)
AUDIVERIS_MXL_RHYTHM_FIX=off

# Python (м„ нғқ)
# PYTHON_BIN=/path/to/venv/bin/python

# м„ңлІ„
PORT=8787
