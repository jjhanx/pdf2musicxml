# pdf2musicxml вҖ” нҷҳкІҪ ліҖмҲҳ мҳҲмӢң (ліөмӮ¬ нӣ„ .env лҳҗлҠ” pm2 ecosystemм—җ м„Өм •)
# Windows PowerShell: Copy-Item .env.example .env
# Linux bash: cp .env.example .env

# в”Җв”Җ OMR м—”м§„ (кё°ліё: Audiveris) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# audiveris (кё°ліё) | pdftomusic (м„ нғқВ·к°ңмқёмҡ©) | ai (мӢӨн—ҳ)
OMR_ENGINE=audiveris

# Audiveris (кё°ліё)
AUDIVERIS_BIN=/opt/audiveris/bin/Audiveris
# AUDIVERIS_OCR_LANG=eng

# PDFtoMusic Pro (OMR_ENGINE=pdftomusic вҖ” мғҒмҡ© SaaS л№„к¶ҢмһҘ, Myriad CLI м•ҪкҙҖ м°ёкі )
# P2MP_BIN=/usr/bin/p2mp
# P2MP_REGISTER=

# AI OMR (OMR_ENGINE=ai мқј л•Ңл§Ң)
# AI_OMR_BACKEND=homr

# MXL нӣ„мІҳлҰ¬ (лҰ¬л“¬ м¶”м • off к¶ҢмһҘ)
AUDIVERIS_MXL_RHYTHM_FIX=off
# AUDIVERIS_MXL_KEEP_REDUNDANT_NATURAL=1
# AUDIVERIS_MXL_ACCIDENTAL_REPAIR=1

# Python (м„ нғқ)
# PYTHON_BIN=/path/to/venv/bin/python

# м„ңлІ„
PORT=8787
